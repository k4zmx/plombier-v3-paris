---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';

const svgWrap = (paths: string) => `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">${paths}</svg>`;

const services = [
  {
    icon: svgWrap('<path d="M7 16.3c2.2 0 4-1.83 4-4.05 0-1.16-.57-2.26-1.71-3.19S7.29 6.75 7 5.3c-.29 1.45-1.14 2.84-2.29 3.76S3 11.1 3 12.25c0 2.22 1.8 4.05 4 4.05z"/><path d="M12.56 6.6A10.97 10.97 0 0 0 14 3.02c.5 2.5 2 4.9 4 6.5s3 3.5 3 5.5a6.98 6.98 0 0 1-11.91 4.97"/>'),
    title: 'Détection de Fuites',
    desc: "Nos spécialistes utilisent des technologies modernes pour identifier rapidement l'origine des fuites. Grâce à notre expertise, nous minimisons les temps d'arrêt et évitons des réparations coûteuses. Que ce soit pour des tuyaux visibles ou des fuites cachées, nos équipes interviennent 24h/24 et 7j/7.",
    img: '/fuites.webp',
    tag: 'URGENT',
  },
  {
    icon: svgWrap('<path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/>'),
    title: 'Chauffagiste',
    desc: "Installation, entretien et réparation de tous types de systèmes de chauffage — chaudières, radiateurs, chauffe-eau. Nos techniciens certifiés interviennent avec soin et expertise pour un confort optimal toute l'année.",
    img: '/chauffagiste.webp',
    tag: 'CERTIFIÉ',
  },
  {
    icon: svgWrap('<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>'),
    title: 'Débouchage de Canalisations',
    desc: "Nos experts utilisent des outils professionnels pour éliminer les obstructions causées par des débris, des racines ou d'autres obstacles. Intervention rapide pour restaurer un écoulement normal, avec suivi après intervention.",
    img: '/debouchage.jpg',
    tag: 'EXPRESS',
  },
  {
    icon: svgWrap('<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>'),
    title: 'Dépannage Plomberie en Urgence',
    desc: "Fuite d'eau, canalisation bouchée ou panne soudaine — chaque minute compte. Notre équipe intervient rapidement, 24h/7j, pour diagnostiquer et résoudre efficacement votre problème et minimiser les dégâts.",
    img: '/depannage.webp',
    tag: 'URGENT',
  },
  {
    icon: svgWrap('<path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/>'),
    title: 'Réparation de Tuyauterie',
    desc: "Fuites, tuyaux rouillés ou joints défectueux — nous proposons des solutions adaptées. Réparations temporaires ou permanentes selon l'urgence, pour prolonger la vie de votre réseau.",
    img: '/tuyauterie.jpg',
    tag: 'CLASSIQUE',
  },
  {
    icon: svgWrap('<path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>'),
    title: 'Installation Systèmes Sanitaires',
    desc: "Service complet d'installation — toilettes, lavabos, douches — garantissant qualité et conformité aux normes. Chaque installation est réalisée avec précision, de la conception à la mise en œuvre.",
    img: '/installations.jpg',
    tag: 'SUR MESURE',
  },
];
---

<Layout
  title="Nos Services Plomberie — Détection Fuite, Débouchage, Chauffe-eau | ZeroFuite"
  description="Tous nos services de plomberie à Paris et Île-de-France : détection de fuites, débouchage de canalisations, chauffagiste, réparation tuyauterie, installation sanitaire. Intervention 24h/24, devis gratuit."
  keywords="services plomberie paris, détection fuite paris, débouchage canalisation, chauffe-eau paris, installation sanitaire, réparation tuyauterie paris"
  schema={{
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Plomberie",
    "provider": {
      "@type": "Plumber",
      "name": "ZeroFuite",
      "telephone": "+33970704559",
      "areaServed": "Paris et Île-de-France"
    },
    "areaServed": [
      { "@type": "City", "name": "Paris" },
      { "@type": "AdministrativeArea", "name": "Île-de-France" }
    ],
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Services de plomberie",
      "itemListElement": services.map((s, i) => ({
        "@type": "Offer",
        "position": i + 1,
        "itemOffered": {
          "@type": "Service",
          "name": s.title,
          "description": s.desc,
          "image": `https://www.example.com${s.img}`
        }
      }))
    }
  }}
>
  <Navbar />
  <main>
    <section class="svc-hero">
      <div class="container">
        <span class="section-label">■ NOS SERVICES</span>
        <h1>Vos experts<br />en plomberie <span class="highlight">24/7</span>.</h1>
        <p>Paris & Île-de-France — Intervention rapide, résultat garanti.</p>
      </div>
    </section>

    <section class="svc-list">
      <div class="container">
        {services.map((s, i) => (
          <article class="svc-row reveal">
            <div class="svc-img-wrap">
              <div class="svc-img-num">0{i + 1}</div>
              <img src={s.img} alt={`${s.title} — Plombier Paris et Île-de-France`} width="800" height="500" loading={i === 0 ? 'eager' : 'lazy'} decoding="async" fetchpriority={i === 0 ? 'high' : 'auto'} />
            </div>
            <div class="svc-content">
              <div class="svc-top">
                <div class="svc-icon" set:html={s.icon}></div>
                <span class={`svc-tag svc-tag--${s.tag === 'URGENT' ? 'red' : 'yellow'}`}>{s.tag}</span>
              </div>
              <h2>{s.title}</h2>
              <p>{s.desc}</p>
              <a href="/contact" class="svc-cta">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                Demander un devis
              </a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <CTA />
  </main>
  <Footer />
</Layout>

<style>
  /* ── Hero ── */
  .svc-hero {
    padding: 100px 0 60px;
    border-bottom: var(--border);
    background: var(--white);
  }

  .svc-hero h1 {
    font-family: var(--font-heading);
    font-size: clamp(40px, 7vw, 72px);
    font-weight: 900;
    line-height: 0.95;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    margin-bottom: 18px;
  }

  .highlight {
    background: var(--yellow);
    padding: 0 12px;
    border: var(--border);
    display: inline-block;
    box-shadow: var(--shadow);
  }

  .svc-hero p {
    font-size: 16px;
    font-weight: 500;
    max-width: 480px;
  }

  /* ── List ── */
  .svc-list {
    padding: var(--section-pad) 0;
  }

  .svc-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    align-items: stretch;
    background: var(--white);
    border: var(--border);
    box-shadow: var(--shadow);
    margin-bottom: 24px;
    overflow: hidden;
  }

  .svc-row:nth-child(even) {
    grid-template-areas: "content img";
  }

  .svc-row:nth-child(even) .svc-img-wrap { grid-area: img; order: 2; }
  .svc-row:nth-child(even) .svc-content { grid-area: content; order: 1; }

  .svc-img-wrap {
    position: relative;
    overflow: hidden;
  }

  .svc-img-wrap img {
    width: 100%;
    height: 100%;
    min-height: 320px;
    object-fit: cover;
    display: block;
  }

  .svc-img-num {
    position: absolute;
    top: 16px;
    left: 16px;
    background: var(--yellow);
    color: var(--black);
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 900;
    padding: 6px 14px;
    border: var(--border);
    box-shadow: var(--shadow-sm);
    letter-spacing: 0.04em;
  }

  .svc-content {
    padding: 36px 36px 36px 16px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .svc-row:nth-child(even) .svc-content {
    padding: 36px 16px 36px 36px;
  }

  .svc-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
  }

  .svc-icon {
    width: 56px;
    height: 56px;
    background: var(--black);
    color: var(--yellow);
    border: var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .svc-tag {
    font-family: var(--font-heading);
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.1em;
    padding: 5px 12px;
    border: var(--border-thin);
    box-shadow: var(--shadow-sm);
  }

  .svc-tag--yellow {
    background: var(--yellow);
    color: var(--black);
  }

  .svc-tag--red {
    background: var(--red);
    color: var(--white);
  }

  .svc-content h2 {
    font-family: var(--font-heading);
    font-size: clamp(24px, 3.5vw, 34px);
    font-weight: 900;
    line-height: 1.1;
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .svc-content p {
    font-size: 15px;
    font-weight: 500;
    line-height: 1.65;
    color: var(--ink);
    margin-bottom: 24px;
  }

  .svc-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--red);
    color: var(--white);
    font-family: var(--font-heading);
    font-size: 15px;
    font-weight: 800;
    padding: 14px 24px;
    border: var(--border);
    box-shadow: var(--shadow);
    text-transform: uppercase;
    width: fit-content;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .svc-cta:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 0 var(--black);
  }

  /* ══════════════ MOBILE ══════════════ */
  @media (max-width: 768px) {
    .svc-hero { padding: 60px 0 40px; }
    .svc-list { padding: 48px 0; }

    .svc-row {
      display: flex !important;
      flex-direction: column;
      grid-template-columns: none !important;
      grid-template-areas: none !important;
      gap: 0;
      margin-bottom: 20px;
      box-shadow: var(--shadow-sm);
    }

    .svc-img-wrap,
    .svc-row:nth-child(even) .svc-img-wrap {
      order: 0 !important;
      width: 100%;
      grid-area: auto !important;
    }

    .svc-content,
    .svc-row:nth-child(even) .svc-content {
      order: 1 !important;
      width: 100%;
      grid-area: auto !important;
      padding: 24px 20px 28px;
    }

    .svc-img-wrap img {
      width: 100%;
      height: 200px;
      min-height: 200px;
      max-height: 220px;
      border-bottom: var(--border);
      display: block;
    }

    .svc-content h2 { font-size: 22px; }
    .svc-content p { font-size: 14px; margin-bottom: 18px; }

    .svc-img-num {
      font-size: 14px;
      padding: 4px 10px;
      border-width: 1.5px;
      top: 12px;
      left: 12px;
    }

    .svc-icon { width: 48px; height: 48px; margin-bottom: 16px; }
    .svc-icon svg { width: 26px; height: 26px; }

    .svc-cta {
      font-size: 14px;
      padding: 12px 20px;
      width: 100%;
      justify-content: center;
      box-shadow: 3px 3px 0 0 var(--black);
    }
    .svc-cta:hover {
      transform: none;
      box-shadow: 3px 3px 0 0 var(--black);
    }
  }
</style>
