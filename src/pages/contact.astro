---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Contact — Plombier Urgence Paris 24h/24 | 09 70 70 45 59"
  description="Contactez votre plombier à Paris et Île-de-France. Disponible 24h/24, 7j/7. Devis gratuit, intervention en 30 minutes. Appelez le 09 70 70 45 59."
  keywords="contact plombier paris, téléphone plombier, numéro plombier urgence, plombier paris contact, devis plomberie"
  schema={{
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "name": "Contact — ZeroFuite",
    "description": "Page de contact du plombier à Paris et Île-de-France",
    "url": "https://www.example.com/contact",
    "mainEntity": {
      "@type": "Plumber",
      "name": "ZeroFuite",
      "telephone": "+33970704559",
      "email": "contact@example.com",
      "areaServed": [
        { "@type": "City", "name": "Paris" },
        { "@type": "AdministrativeArea", "name": "Île-de-France" }
      ],
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Paris",
        "addressRegion": "Île-de-France",
        "addressCountry": "FR"
      },
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
        "opens": "00:00",
        "closes": "23:59"
      }
    }
  }}
>
  <Navbar />
  <main>
    <section class="c-hero">
      <div class="container">
        <div class="c-badge">
          <span class="c-dot" aria-hidden="true"></span>
          Disponible 24h/24 · 7j/7
        </div>
        <h1>Parlons de<br /><span class="highlight">votre urgence</span>.</h1>
        <p>Devis gratuit sur place. Un seul appel et on est chez vous en 30 minutes.</p>
      </div>
    </section>

    <section class="c-main">
      <div class="container">
        <div class="c-grid">
          <div class="c-cards">
            <a href="tel:09 70 70 45 59" class="c-card c-card--primary">
              <div class="c-card-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.85 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.77 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </div>
              <div class="c-card-content">
                <span class="c-card-label">Téléphone</span>
                <span class="c-card-value">09 70 70 45 59</span>
                <span class="c-card-sub">Appel non surtaxé · Réponse immédiate</span>
              </div>
              <svg class="c-card-arrow" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>

            <div class="c-card">
              <div class="c-card-icon c-card-icon--yellow">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div class="c-card-content">
                <span class="c-card-label">Zone d'intervention</span>
                <span class="c-card-value">Paris & Île-de-France</span>
                <span class="c-card-sub">75 · 77 · 78 · 91 · 92 · 93 · 94 · 95</span>
              </div>
            </div>

            <div class="c-card">
              <div class="c-card-icon c-card-icon--yellow">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
              </div>
              <div class="c-card-content">
                <span class="c-card-label">Déplacement</span>
                <span class="c-card-value">À partir de 39 €</span>
                <span class="c-card-sub">Devis gratuit sur place · Aucun frais caché</span>
              </div>
            </div>
          </div>

          <div class="c-info">
            <div class="c-info-card">
              <h2>Horaires</h2>
              <div class="hours-grid">
                <div class="hours-row">
                  <span class="hours-day">Lundi – Dimanche</span>
                  <span class="hours-time">24h / 24</span>
                </div>
                <div class="hours-row">
                  <span class="hours-day">Jours fériés</span>
                  <span class="hours-time">Disponible</span>
                </div>
              </div>
              <div class="hours-note">
                <span class="hours-note-dot" aria-hidden="true"></span>
                Intervention 30 min · Devis gratuit · Plombier assuré
              </div>
            </div>

            <div class="c-info-card">
              <h2>Nos garanties</h2>
              <ul class="guarantees">
                <li><span class="check" aria-hidden="true">✓</span>Prix annoncé avant intervention</li>
                <li><span class="check" aria-hidden="true">✓</span>Plombier qualifié & assuré RC Pro</li>
                <li><span class="check" aria-hidden="true">✓</span>Garantie sur chaque intervention</li>
                <li><span class="check" aria-hidden="true">✓</span>Paiement après intervention uniquement</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  /* ── Hero ── */
  .c-hero {
    padding: 100px 0 60px;
    border-bottom: var(--border);
    background: var(--white);
  }

  .c-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--green);
    border: var(--border-thin);
    box-shadow: var(--shadow-sm);
    padding: 6px 14px;
    font-family: var(--font-heading);
    font-size: 13px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--black);
    margin-bottom: 24px;
  }

  .c-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--black);
    animation: blink 1.2s ease-in-out infinite;
  }

  @keyframes blink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0.3; }
  }

  .c-hero h1 {
    font-family: var(--font-heading);
    font-size: clamp(40px, 7vw, 72px);
    font-weight: 900;
    line-height: 0.95;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  .highlight {
    background: var(--yellow);
    padding: 0 12px;
    border: var(--border);
    display: inline-block;
    box-shadow: var(--shadow);
  }

  .c-hero p {
    font-size: 16px;
    font-weight: 500;
    max-width: 500px;
  }

  /* ── Main ── */
  .c-main { padding: var(--section-pad) 0; }

  .c-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    align-items: start;
  }

  .c-cards {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* ── Contact card ── */
  .c-card {
    display: flex;
    align-items: center;
    gap: 20px;
    background: var(--white);
    border: var(--border);
    box-shadow: var(--shadow);
    padding: 22px 24px;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .c-card:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 0 var(--black);
  }

  .c-card--primary {
    background: var(--red);
    color: var(--white);
  }

  .c-card-icon {
    width: 56px;
    height: 56px;
    background: var(--black);
    color: var(--yellow);
    border: var(--border-thin);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .c-card-icon--yellow {
    background: var(--yellow);
    color: var(--black);
  }

  .c-card--primary .c-card-icon {
    background: var(--white);
    color: var(--red);
  }

  .c-card-content {
    flex: 1;
    min-width: 0;
  }

  .c-card-label {
    display: block;
    font-family: var(--font-heading);
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.7;
    margin-bottom: 2px;
  }

  .c-card-value {
    display: block;
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    margin-bottom: 4px;
  }

  .c-card-sub {
    display: block;
    font-size: 12px;
    font-weight: 500;
    opacity: 0.75;
  }

  .c-card-arrow {
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .c-card--primary:hover .c-card-arrow {
    transform: translateX(4px);
  }

  /* ── Info ── */
  .c-info {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .c-info-card {
    background: var(--white);
    border: var(--border);
    box-shadow: var(--shadow);
    padding: 28px 24px;
  }

  .c-info-card h2 {
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 18px;
    padding-bottom: 12px;
    border-bottom: 2px solid var(--black);
  }

  .hours-grid {
    display: flex;
    flex-direction: column;
    margin-bottom: 18px;
  }

  .hours-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 0;
    border-bottom: 1px solid #e5e5e5;
  }

  .hours-row:last-child { border-bottom: none; }

  .hours-day {
    font-size: 14px;
    font-weight: 500;
  }

  .hours-time {
    font-family: var(--font-heading);
    font-size: 15px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .hours-note {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    font-weight: 600;
    color: var(--ink);
    padding: 10px 12px;
    background: var(--yellow);
    border: var(--border-thin);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .hours-note-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--black);
    flex-shrink: 0;
  }

  /* ── Guarantees ── */
  .guarantees {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .guarantees li {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 14px;
    font-weight: 600;
    color: var(--black);
  }

  .check {
    width: 24px;
    height: 24px;
    background: var(--green);
    border: var(--border-thin);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: 14px;
    flex-shrink: 0;
  }

  /* ══════════════ MOBILE ══════════════ */
  @media (max-width: 768px) {
    .c-hero { padding: 60px 0 40px; }
    .c-main { padding: 48px 0; }

    .c-grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .c-card {
      padding: 16px 18px;
      gap: 14px;
      box-shadow: var(--shadow-sm);
    }
    .c-card:hover {
      transform: none;
      box-shadow: var(--shadow-sm);
    }

    .c-card-icon { width: 44px; height: 44px; }
    .c-card-icon svg { width: 22px; height: 22px; }

    .c-card-value { font-size: 18px; }
    .c-card-sub { font-size: 11px; }

    .c-info-card {
      padding: 22px 20px;
      box-shadow: var(--shadow-sm);
    }
  }
</style>
