---
const starPath = 'M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.27 5.82 22 7 14.14l-5-4.87 6.91-1.01z';

const reviews = [
  { name: 'Claire D.', date: 'Il y a 2 semaines', stars: 5, text: "Fuite d'eau en soirée, arrivé vite, tout sécurisé et expliqué clairement. Propre et efficace." },
  { name: 'Thomas L.', date: 'Il y a 1 mois', stars: 4.5, text: "Urgence gérée rapidement, pas de mauvaise surprise sur le tarif. Je recommande." },
  { name: 'Julien R.', date: 'Il y a 3 semaines', stars: 4, text: "Fuite d'eau en pleine nuit, intervention rapide et devis clair. Bon travail." },
  { name: 'Nadia B.', date: 'Il y a 2 mois', stars: 4, text: "Diagnostic rapide, réparation durable. Pro et rassurant, rien à redire." },
  { name: 'Antoine P.', date: 'Il y a 1 semaine', stars: 3.5, text: "Intervention après dégât des eaux. Devis annoncé avant, travail correct." },
  { name: 'Samira K.', date: 'Il y a 1 mois', stars: 4, text: "WC bouchés : réactif, efficace et sans dégâts. Laisse tout propre après." },
  { name: 'Paul M.', date: 'Il y a 3 mois', stars: 4, text: "Problème réglé rapidement, le technicien a pris le temps d'expliquer." },
  { name: 'Élodie G.', date: 'Il y a 5 jours', stars: 3.5, text: "Réparation de tuyauterie propre, pas de fuite depuis. Tarif correct." },
];
---

<section class="reviews" id="avis">
  <div class="container">
    <div class="reviews-header reveal">
      <div class="google-banner">
        <svg width="22" height="22" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18A10.96 10.96 0 0 0 1 12c0 1.77.42 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        <span class="g-word">
          <span style="color:#4285F4">G</span><span style="color:#EA4335">o</span><span style="color:#FBBC05">o</span><span style="color:#4285F4">g</span><span style="color:#34A853">l</span><span style="color:#EA4335">e</span>
        </span>
        <span class="g-reviews">Reviews</span>
      </div>
      <h2>87 clients<br /><span class="highlight">ne peuvent pas</span><br />se tromper.</h2>
      <div class="rating-strip">
        <span class="rating-num">4.5</span>
        <div class="rating-stars">
          {Array.from({ length: 5 }).map((_, i) => (
            <svg width="24" height="24" viewBox="0 0 24 24" fill={i < 4 ? '#000' : 'none'} stroke="#000" stroke-width="2" aria-hidden="true">
              <path d={starPath}/>
            </svg>
          ))}
        </div>
        <span class="rating-text">basé sur 87 avis</span>
      </div>
    </div>

    <div class="reviews-slider" data-rv-slider>
      <button class="rv-arrow rv-arrow--prev" aria-label="Précédent">‹</button>

      <div class="rv-track">
        {reviews.map((r, idx) => (
          <article class="rv-note">
            <div class="rv-top">
              <div class="rv-google">
                <svg width="16" height="16" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
                  <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                  <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18A10.96 10.96 0 0 0 1 12c0 1.77.42 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
                  <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
                <span class="rv-g-text">
                  <span style="color:#4285F4">G</span><span style="color:#EA4335">o</span><span style="color:#FBBC05">o</span><span style="color:#4285F4">g</span><span style="color:#34A853">l</span><span style="color:#EA4335">e</span>
                </span>
              </div>
              <span class="rv-verified">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#34A853" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                Vérifié
              </span>
            </div>
            <div class="rv-stars">
              {Array.from({ length: 5 }).map((_, i) => {
                if (i < Math.floor(r.stars)) {
                  return <svg width="14" height="14" viewBox="0 0 24 24" fill="#000" aria-hidden="true"><path d={starPath}/></svg>;
                } else if (i < r.stars) {
                  return <svg width="14" height="14" viewBox="0 0 24 24" aria-hidden="true"><defs><linearGradient id={`rh${idx}`}><stop offset="50%" stop-color="#000"/><stop offset="50%" stop-color="transparent"/></linearGradient></defs><path d={starPath} fill={`url(#rh${idx})`} stroke="#000" stroke-width="1.5"/></svg>;
                } else {
                  return <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="1.5" aria-hidden="true"><path d={starPath}/></svg>;
                }
              })}
            </div>
            <p class="rv-text">"{r.text}"</p>
            <div class="rv-footer">
              <span class="rv-name">— {r.name}</span>
              <span class="rv-date">{r.date}</span>
            </div>
          </article>
        ))}
      </div>

      <button class="rv-arrow rv-arrow--next" aria-label="Suivant">›</button>
    </div>
  </div>
</section>

<script>
  (function() {
    const slider = document.querySelector('[data-rv-slider]');
    if (!slider) return;
    const track = slider.querySelector('.rv-track') as HTMLElement;
    const prevBtn = slider.querySelector('.rv-arrow--prev');
    const nextBtn = slider.querySelector('.rv-arrow--next');
    let paused = false;
    let jumping = false;
    const speed = 0.5;

    function step() {
      if (!paused && !jumping) {
        track.scrollLeft += speed;
        if (track.scrollLeft >= track.scrollWidth - track.clientWidth - 1) {
          track.scrollLeft = 0;
        }
      }
      requestAnimationFrame(step);
    }
    requestAnimationFrame(step);

    track.addEventListener('mouseenter', () => paused = true);
    track.addEventListener('mouseleave', () => paused = false);
    track.addEventListener('touchstart', () => paused = true, { passive: true });
    track.addEventListener('touchend', () => paused = false);

    function jumpTo(dir: number) {
      jumping = true;
      const card = track.firstElementChild as HTMLElement;
      const cardW = card ? card.offsetWidth + 24 : 300;
      const idx = Math.round(track.scrollLeft / cardW) + dir;
      track.scrollTo({ left: Math.max(0, idx * cardW), behavior: 'smooth' });
      setTimeout(() => { jumping = false; }, 500);
    }

    prevBtn?.addEventListener('click', () => jumpTo(-1));
    nextBtn?.addEventListener('click', () => jumpTo(1));
  })();
</script>

<style>
  .reviews {
    padding: clamp(48px, 8vw, 96px) 0;
    background: var(--white);
    border-bottom: var(--border);
    overflow: hidden;
  }

  .reviews-header {
    text-align: center;
    margin-bottom: 56px;
  }

  .google-banner {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--white);
    border: var(--border-thin);
    padding: 6px 14px;
    box-shadow: 3px 3px 0 0 var(--black);
    margin-bottom: 20px;
  }

  .g-word {
    font-family: 'Inter', sans-serif;
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .g-word span { display: inline-block; }

  .g-reviews {
    font-family: var(--font-heading);
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.12em;
    color: var(--black);
    text-transform: uppercase;
  }

  .reviews-header h2 {
    font-family: var(--font-heading);
    font-size: clamp(36px, 6vw, 64px);
    font-weight: 900;
    line-height: 0.95;
    letter-spacing: -0.02em;
    color: var(--black);
    margin-bottom: 24px;
    text-transform: uppercase;
  }

  .highlight {
    background: var(--yellow);
    padding: 0 12px;
    border: var(--border);
    display: inline-block;
    box-shadow: var(--shadow);
  }

  .rating-strip {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: var(--black);
    color: var(--white);
    padding: 10px 18px;
    border: var(--border-thin);
    box-shadow: 4px 4px 0 0 var(--black);
  }

  .rating-num {
    font-family: var(--font-heading);
    font-size: 24px;
    font-weight: 900;
    color: var(--yellow);
  }

  .rating-stars {
    display: flex;
    gap: 3px;
    background: var(--yellow);
    padding: 4px 8px;
    border: 2px solid var(--white);
  }

  .rating-stars svg { fill: #000; }

  .rating-text {
    font-family: var(--font-heading);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* ── Slider ── */
  .reviews-slider {
    position: relative;
  }

  .rv-track {
    display: flex;
    gap: 24px;
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    padding: 24px 40px;
    mask-image: linear-gradient(to right, transparent 0%, black 4%, black 96%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 4%, black 96%, transparent 100%);
  }

  .rv-track::-webkit-scrollbar { display: none; }

  /* ── Arrows ── */
  .rv-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 48px;
    height: 48px;
    background: var(--yellow);
    color: var(--black);
    border: var(--border);
    box-shadow: var(--shadow-sm);
    font-family: var(--font-heading);
    font-size: 32px;
    font-weight: 900;
    line-height: 1;
    z-index: 2;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .rv-arrow:hover {
    transform: translateY(-50%) translate(-2px, -2px);
    box-shadow: 6px 6px 0 0 var(--black);
  }

  .rv-arrow:active {
    transform: translateY(-50%) translate(2px, 2px);
    box-shadow: 2px 2px 0 0 var(--black);
  }

  .rv-arrow--prev { left: -12px; }
  .rv-arrow--next { right: -12px; }

  /* ── Note card (sticky note style) ── */
  .rv-note {
    position: relative;
    flex: 0 0 300px;
    padding: 24px;
    background: var(--white);
    border: var(--border);
    box-shadow: var(--shadow);
    border-top: 6px solid var(--yellow);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .rv-note:hover {
    transform: translate(-3px, -3px);
    box-shadow: 7px 7px 0 0 var(--black);
  }

  .rv-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    padding-bottom: 12px;
    margin-bottom: 14px;
    border-bottom: 1px dashed #ccc;
  }

  .rv-google {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .rv-g-text {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .rv-g-text span { display: inline-block; }

  .rv-verified {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 700;
    color: #34A853;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: rgba(52, 168, 83, 0.1);
    padding: 3px 8px;
    border-radius: 12px;
  }

  .rv-stars {
    display: flex;
    gap: 3px;
    margin-bottom: 14px;
  }

  .rv-text {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    line-height: 1.6;
    margin-bottom: 20px;
    min-height: 80px;
  }

  .rv-footer {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding-top: 14px;
    border-top: 2px solid var(--black);
  }

  .rv-name {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 14px;
    text-transform: uppercase;
  }

  .rv-date {
    font-size: 11px;
    font-weight: 500;
    opacity: 0.7;
  }

  @media (max-width: 768px) {
    .reviews { padding: 56px 0; }
    .reviews-header { margin-bottom: 36px; }

    .google-banner {
      padding: 5px 12px;
      box-shadow: 2px 2px 0 0 var(--black);
    }
    .google-banner span { font-size: 11px; }

    .rv-track { gap: 16px; padding: 18px 8px; }
    .rv-note {
      flex: 0 0 260px;
      padding: 20px 18px;
      box-shadow: 3px 3px 0 0 var(--black);
    }
    .rv-note:hover {
      transform: none;
      box-shadow: 3px 3px 0 0 var(--black);
    }
    .rv-text { font-size: 14px; min-height: 70px; margin-bottom: 16px; }
    .rv-name { font-size: 13px; }
    .rv-date { font-size: 10px; }


    .rv-arrow {
      width: 42px; height: 42px;
      font-size: 24px;
      border-width: 2px;
      box-shadow: 3px 3px 0 0 var(--black);
    }
    .rv-arrow:hover {
      transform: translateY(-50%);
      box-shadow: 3px 3px 0 0 var(--black);
    }
    .rv-arrow--prev { left: 4px; }
    .rv-arrow--next { right: 4px; }

    .rating-strip {
      flex-wrap: wrap;
      gap: 8px;
      padding: 8px 14px;
      box-shadow: 3px 3px 0 0 var(--black);
    }
    .rating-num { font-size: 20px; }
    .rating-text { font-size: 10px; }
    .rating-stars svg { width: 18px; height: 18px; }

  }
</style>
