<footer class="footer">
  <div class="footer-inner container">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="footer-logo">
          <div class="logo-box">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
          </div>
          <span>ZeroFuite</span>
        </div>
        <p>Votre plombier de confiance, disponible 24h/24 et 7j/7 à Paris et en Île-de-France.</p>
      </div>

      <div class="footer-col">
        <h3>Navigation</h3>
        <a href="/">Accueil</a>
        <a href="/services">Services</a>
        <a href="/contact">Contact</a>
      </div>

      <div class="footer-col">
        <h3>Contact</h3>
        <a href="tel:09 70 70 45 59" class="footer-phone">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.85 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.77 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          09 70 70 45 59
        </a>
        <span class="footer-info">24h/24 · 7j/7</span>
        <span class="footer-info">Paris & Île-de-France</span>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p>© 2026 ZEROFUITE — TOUS DROITS RÉSERVÉS</p>
      <a href="#">Mentions légales</a>
    </div>
  </div>
</footer>

<!-- Sticky call button -->
<a href="tel:09 70 70 45 59" class="sticky-cta">
  <span class="sticky-cta-dot" aria-hidden="true"></span>
  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.85 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.77 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
  APPELEZ MAINTENANT
</a>

<style>
  .footer {
    background: var(--black);
    color: var(--white);
    position: relative;
  }

  .footer-inner {
    padding-top: 60px;
    padding-bottom: 40px;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 40px;
  }

  /* ── Brand ── */
  .footer-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
  }

  .footer-logo .logo-box {
    width: 36px;
    height: 36px;
    background: var(--yellow);
    border: var(--border-thin);
    box-shadow: 3px 3px 0 0 var(--white);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .footer-logo span {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 900;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--white);
  }

  .footer-brand p {
    font-size: 14px;
    color: #aaa;
    line-height: 1.6;
    max-width: 320px;
  }

  /* ── Col ── */
  .footer-col h3 {
    font-family: var(--font-heading);
    font-size: 14px;
    font-weight: 900;
    color: var(--yellow);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 16px;
    padding-bottom: 10px;
    border-bottom: 2px solid var(--yellow);
  }

  .footer-col a {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 15px;
    font-weight: 700;
    color: var(--white);
    padding: 6px 0;
    margin-right: 12px;
    text-transform: uppercase;
    position: relative;
    transition: color 0.2s ease;
  }

  .footer-col a::after {
    content: '';
    position: absolute;
    bottom: 2px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--yellow);
    transition: width 0.3s ease;
  }

  .footer-col a:hover {
    color: var(--yellow);
  }

  .footer-col a:hover::after {
    width: 100%;
  }

  .footer-phone {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--yellow) !important;
    font-size: 17px !important;
  }

  .footer-info {
    display: block;
    font-size: 13px;
    color: #aaa;
    padding: 4px 0;
  }

  /* ── Bottom ── */
  .footer-bottom {
    padding: 20px 0;
    border-top: 1px solid #333;
  }

  .footer-bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-bottom p {
    font-family: var(--font-heading);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: #aaa;
  }

  .footer-bottom a {
    font-family: var(--font-heading);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: #aaa;
    text-transform: uppercase;
  }

  .footer-bottom a:hover { color: var(--yellow); }

  /* ══════════════ STICKY CTA ══════════════ */
  .sticky-cta {
    position: fixed;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 990;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--red);
    color: var(--white);
    font-family: var(--font-heading);
    font-size: 15px;
    font-weight: 800;
    padding: 14px 24px;
    border: var(--border);
    box-shadow: var(--shadow);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    white-space: nowrap;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    -webkit-tap-highlight-color: transparent;
  }

  .sticky-cta:hover {
    transform: translateX(-50%) translate(-2px, -2px);
    box-shadow: 8px 8px 0 0 var(--black);
  }

  .sticky-cta:active {
    transform: translateX(-50%) translate(2px, 2px);
    box-shadow: 2px 2px 0 0 var(--black);
  }

  .sticky-cta-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--green);
    border: 2px solid var(--white);
    animation: blink 1.2s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes blink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0.3; }
  }

  @media (max-width: 768px) {
    .footer-inner { padding-top: 40px; padding-bottom: 28px; }
    .footer-grid { grid-template-columns: 1fr; gap: 28px; }
    .footer-brand p { font-size: 13px; }
    .footer-col h3 { font-size: 13px; margin-bottom: 12px; }
    .footer-col a { font-size: 14px; padding: 5px 0; }
    .footer-phone { font-size: 16px !important; }

    .footer-bottom { padding: 14px 0; }
    .footer-bottom-inner { flex-direction: column; gap: 6px; text-align: center; }
    .footer-bottom p, .footer-bottom a { font-size: 10px; }

    .sticky-cta {
      font-size: 12px;
      padding: 11px 18px;
      bottom: 12px;
      border-width: 2px;
      box-shadow: 4px 4px 0 0 var(--black);
      gap: 8px;
    }
    .sticky-cta:hover {
      transform: translateX(-50%);
      box-shadow: 4px 4px 0 0 var(--black);
    }
    .sticky-cta svg { width: 16px; height: 16px; }
  }
</style>
