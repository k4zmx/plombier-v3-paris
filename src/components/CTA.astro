<section class="cta" id="contact">
  <div class="container">
    <div class="cta-block reveal">
      <div class="cta-stripes" aria-hidden="true"></div>

      <div class="cta-tag">URGENCE ?</div>

      <h2>
        On arrive<br />
        <span class="cta-highlight">en 30 minutes.</span>
      </h2>

      <p>Un seul appel. Paris & Île-de-France, 24h/24.</p>

      <a href="tel:09 70 70 45 59" class="cta-phone">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.85 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.77 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        09 70 70 45 59
      </a>

      <p class="cta-sub">Appel non surtaxé · Devis gratuit · Paiement après intervention</p>
    </div>
  </div>
</section>

<style>
  .cta {
    padding: var(--section-pad) 0;
    background: var(--yellow);
    border-bottom: var(--border);
  }

  .cta-block {
    position: relative;
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
    background: var(--white);
    border: var(--border);
    box-shadow: 10px 10px 0 0 var(--black);
    padding: 56px 48px;
    overflow: hidden;
  }

  /* Diagonal stripes background */
  .cta-stripes {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 1px 1px, rgba(0, 0, 0, 0.08) 1px, transparent 1px);
    background-size: 16px 16px;
    pointer-events: none;
  }

  .cta-block > *:not(.cta-stripes) {
    position: relative;
    z-index: 1;
  }

  .cta-tag {
    display: inline-block;
    background: var(--red);
    color: var(--white);
    font-family: var(--font-heading);
    font-size: 16px;
    font-weight: 900;
    padding: 8px 20px;
    border: var(--border);
    box-shadow: 4px 4px 0 0 var(--black);
    letter-spacing: 0.1em;
    margin-bottom: 28px;
  }

  .cta-block h2 {
    font-family: var(--font-heading);
    font-size: clamp(40px, 7vw, 72px);
    font-weight: 900;
    line-height: 0.95;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  .cta-highlight {
    background: var(--yellow);
    padding: 0 16px;
    border: 3px solid var(--black);
    display: inline-block;
    box-shadow: 5px 5px 0 0 var(--black);
  }

  .cta-block p {
    font-size: 17px;
    font-weight: 500;
    color: var(--black);
    margin-bottom: 32px;
  }

  .cta-phone {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    background: var(--black);
    color: var(--yellow);
    font-family: var(--font-heading);
    font-size: clamp(22px, 4vw, 32px);
    font-weight: 900;
    padding: 20px 36px;
    border: var(--border);
    box-shadow: 8px 8px 0 0 var(--black);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    margin-bottom: 16px;
  }

  .cta-phone:hover {
    transform: translate(-3px, -3px);
    box-shadow: 11px 11px 0 0 var(--red);
    background: var(--red);
    color: var(--white);
  }

  .cta-phone:active {
    transform: translate(3px, 3px);
    box-shadow: 2px 2px 0 0 var(--black);
  }

  .cta-sub {
    font-size: 13px;
    font-weight: 600;
    color: var(--ink);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  @media (max-width: 768px) {
    .cta { padding: 56px 0; }

    .cta-block {
      padding: 40px 20px;
      border-width: 2px;
      box-shadow: 6px 6px 0 0 var(--black);
    }

    .cta-tag {
      font-size: 14px;
      padding: 6px 14px;
      border-width: 2px;
      box-shadow: 3px 3px 0 0 var(--black);
      margin-bottom: 22px;
    }

    .cta-block h2 {
      font-size: clamp(34px, 10vw, 52px);
      margin-bottom: 14px;
    }

    .cta-highlight {
      padding: 0 10px;
      border-width: 2px;
      box-shadow: 4px 4px 0 0 var(--black);
    }

    .cta-block p { font-size: 14px; margin-bottom: 26px; }

    .cta-phone {
      width: 100%;
      justify-content: center;
      padding: 16px 20px;
      font-size: clamp(20px, 6vw, 26px);
      gap: 10px;
      border-width: 2px;
      box-shadow: 5px 5px 0 0 var(--black);
    }
    .cta-phone:hover {
      transform: none;
      box-shadow: 5px 5px 0 0 var(--black);
      background: var(--black);
      color: var(--yellow);
    }
    .cta-phone svg { width: 22px; height: 22px; }

    .cta-sub { font-size: 11px; }
  }
</style>
